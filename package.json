{
  "name": "convergence",
  "version": "0.0.0",
  "description": "UI-first desktop app for managing agent work across local codebases",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-rebuild --force -o better-sqlite3 && electron-vite dev",
    "dev:clean": "node tools/dev-clean.mjs",
    "build": "electron-rebuild --force -o better-sqlite3 && electron-vite build",
    "build:preview": "electron-vite build && electron-vite preview",
    "test": "npm rebuild better-sqlite3 > /dev/null 2>&1; vitest run",
    "test:pure": "npm rebuild better-sqlite3 > /dev/null 2>&1; vitest run --config vitest.pure.config.ts",
    "test:unit": "npm rebuild better-sqlite3 > /dev/null 2>&1; vitest run --config vitest.unit.config.ts",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "rebuild:electron": "electron-rebuild -o better-sqlite3"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toast": "^1.2.15",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^41.2.0",
    "electron-vite": "^5.0.0",
    "eslint": "^10.2.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^7.3.2",
    "vitest": "^4.1.4"
  }
}
